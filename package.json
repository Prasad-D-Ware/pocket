{
  "name": "pocket",
  "scripts": {
    "android": "expo run:android",
    "android:build": "expo prebuild -p android",
    "build": "tsc --noEmit && npm run android:build",
    "ci": "tsc --noEmit && npm run lint:check && npm run format:check && npm run android:build",
    "dev": "expo start --clear --dev-client --reset-cache",
    "doctor": "npx -y expo-doctor@latest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ios": "expo run:ios",
    "lint": "expo lint --fix",
    "lint:check": "expo lint",
    "start": "expo start",
    "test": "tsx --test 'src/**/__tests__/*.test.ts'",
    "test:policy": "tsx --test 'src/policy/__tests__/*.test.ts'",
    "test:inbox": "tsx --test 'src/inbox/__tests__/*.test.ts'",
    "web": "expo start --web"
  },
  "displayName": "Pocket",
  "description": "Pocket — a mobile-native Solana wallet for AI agents. Policy-bound signing, Pay.sh / x402 client, on-device LLM intent parser, Android Keystore-backed Ed25519. Reference implementation of MoonPay OWS on Solana.",
  "usecase": "Mobile",
  "keywords": [
    "expo",
    "mobile-wallet-adapter",
    "react-native",
    "solana-kit",
    "uniwind",
    "tailwind"
  ],
  "main": "./index.js",
  "version": "1.0.0",
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@expo/metro-runtime": "~55.0.6",
    "@solana-program/system": "^0.12.2",
    "@solana/kit": "^6.1.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@wallet-ui/react-native-kit": "^4.0.1",
    "bs58": "^6.0.0",
    "buffer": "^6.0.3",
    "expo": "~55.0.23",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "^55.0.18",
    "expo-file-system": "~55.0.22",
    "expo-haptics": "~55.0.14",
    "expo-linking": "~55.0.8",
    "expo-router": "~55.0.7",
    "expo-sqlite": "~55.0.16",
    "expo-status-bar": "~55.0.4",
    "llama.rn": "^0.12.4",
    "react": "~19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-quick-crypto": "^1.0.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.5",
    "tailwindcss": "~4.1.16",
    "tweetnacl": "^1.0.3",
    "uniwind": "~1.0.0",
    "x402-solana": "^2.0.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "~19.2.14",
    "better-sqlite3": "^12.10.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "prettier": "^3.8.1",
    "tsx": "^4.22.3",
    "typescript": "~5.9.2"
  },
  "private": true,
  "overrides": {
    "react-native-quick-base64": "^3.0.0"
  }
}
